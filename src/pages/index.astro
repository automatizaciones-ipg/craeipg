---
import Layout from "../layouts/Layout.astro";
import ResourceGrid from "../components/ResourceGrid.tsx";
import WelcomeSection from "../components/WelcomeSection.tsx";
import HeroSearch from "../components/HeroSearch.tsx";
---

<Layout title="CRAE - Centro de Recursos Estudiantiles IPG">
  {
    /* z-[100] asegura que el menú desplegable del buscador flote sobre el resto de la página */
  }
  <header class="mt-4 md:mt-8 relative z-[100] px-4 md:px-0">
    <div
      class="relative w-full rounded-[2.5rem] p-6 md:p-24 bg-white border border-slate-200/60 shadow-2xl shadow-blue-900/5 group"
    >
      {/* --- 1. CAPA DE FONDO ANIMADO (Aislada con overflow-hidden) --- */}
      <div
        class="absolute inset-0 w-full h-full rounded-[2.5rem] overflow-hidden pointer-events-none z-0"
      >
        <div
          class="absolute -top-32 left-1/2 -translate-x-1/2 w-[40rem] md:w-[60rem] h-[20rem] md:h-[30rem] bg-gradient-to-b from-blue-100/80 to-transparent rounded-[100%] blur-3xl opacity-100"
        >
        </div>

        <div
          class="absolute -top-20 -right-20 md:top-0 md:right-0 w-64 md:w-[35rem] h-64 md:h-[35rem] bg-blue-400/10 md:bg-blue-500/10 rounded-full mix-blend-multiply blur-3xl animate-blob"
        >
        </div>
        <div
          class="absolute -bottom-20 -left-20 md:-bottom-20 md:left-10 w-64 md:w-[35rem] h-64 md:h-[35rem] bg-indigo-400/10 md:bg-indigo-500/10 rounded-full mix-blend-multiply blur-3xl animate-blob animation-delay-2000"
        >
        </div>
        <div
          class="hidden md:block absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[45rem] h-[45rem] bg-sky-200/15 rounded-full mix-blend-multiply blur-3xl animate-blob animation-delay-4000"
        >
        </div>

        <div
          class="absolute top-1/4 left-[10%] md:left-[20%] w-1.5 h-1.5 bg-blue-500 rounded-full shadow-[0_0_20px_4px_rgba(59,130,246,0.8)] animate-sparkle"
        >
        </div>
        <div
          class="absolute top-1/3 right-[10%] md:right-[25%] w-2 h-2 bg-indigo-500 rounded-full shadow-[0_0_25px_5px_rgba(99,102,241,0.8)] animate-sparkle animation-delay-2000"
        >
        </div>
        <div
          class="hidden md:block absolute bottom-1/4 left-[30%] w-1.5 h-1.5 bg-blue-400 rounded-full shadow-[0_0_20px_4px_rgba(96,165,250,0.8)] animate-sparkle animation-delay-4000"
        >
        </div>
        <div
          class="absolute top-[65%] right-[15%] md:right-[20%] w-2 h-2 bg-sky-400 rounded-full shadow-[0_0_20px_4px_rgba(56,189,248,0.8)] animate-sparkle animation-delay-1000"
        >
        </div>
      </div>
      {/* --- FIN CAPA DE FONDO --- */}

      {
        /* --- 2. CAPA DE CONTENIDO PRINCIPAL (SIN overflow-hidden, centrado absoluto) --- */
      }
      <div
        class="relative z-10 w-full flex flex-col items-center justify-center text-center"
      >
        <span
          class="inline-flex items-center gap-2 py-1.5 px-5 rounded-full bg-white/80 backdrop-blur-md border border-blue-100 text-blue-700 text-xs md:text-sm font-bold mb-8 tracking-wide shadow-[0_2px_10px_rgba(37,99,235,0.06)] uppercase"
        >
          <span class="w-2 h-2 rounded-full bg-blue-600 animate-pulse-slow"
          ></span>
          Plataforma de Recursos Estudiantiles
        </span>

        <h1
          class="text-4xl md:text-6xl lg:text-7xl font-extrabold text-slate-800 mb-6 tracking-tight leading-[1.15]"
        >
          Bienvenido a <br class="block md:hidden" />
          <span
            class="text-transparent bg-clip-text bg-gradient-to-r from-blue-900 via-blue-600 to-indigo-500 drop-shadow-sm"
          >
            CRAE IPG
          </span>
        </h1>

        <p
          class="text-base md:text-xl text-slate-600 max-w-2xl mx-auto leading-relaxed mb-12 font-medium"
        >
          Encuentra guías, normativas, formatos institucionales y herramientas
          digitales diseñadas para impulsar tu éxito académico en IPG.
        </p>

        <div
          class="w-full max-w-3xl mx-auto transform transition-all duration-300 hover:scale-[1.01] justify-center flex"
        >
          <HeroSearch client:load />
        </div>
      </div>
    </div>
  </header>

  <WelcomeSection client:visible />
  <ResourceGrid client:visible />
</Layout>

<style is:global>
  @keyframes blob {
    0% {
      transform: translate(0px, 0px) scale(1);
    }
    33% {
      transform: translate(40px, -60px) scale(1.05);
    }
    66% {
      transform: translate(-30px, 40px) scale(0.95);
    }
    100% {
      transform: translate(0px, 0px) scale(1);
    }
  }
  @keyframes sparkle {
    0%,
    100% {
      opacity: 0;
      transform: scale(0.5);
    }
    50% {
      opacity: 1;
      transform: scale(1.2);
    }
  }
  @keyframes pulse-slow {
    0%,
    100% {
      opacity: 0.5;
    }
    50% {
      opacity: 1;
    }
  }
  .animate-blob {
    animation: blob 12s infinite ease-in-out;
  }
  .animate-sparkle {
    animation: sparkle 5s infinite ease-in-out;
  }
  .animate-pulse-slow {
    animation: pulse-slow 4s infinite ease-in-out;
  }
  .animation-delay-1000 {
    animation-delay: 1s;
  }
  .animation-delay-2000 {
    animation-delay: 2s;
  }
  .animation-delay-3000 {
    animation-delay: 3s;
  }
  .animation-delay-4000 {
    animation-delay: 4s;
  }
</style>
