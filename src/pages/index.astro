---
import Layout from "../layouts/Layout.astro";
import ResourceGrid from "../components/ResourceGrid.tsx";
import WelcomeSection from "../components/WelcomeSection.tsx";
import HeroSearch from "../components/HeroSearch.tsx";
---

<Layout title="CRAE - Centro de Recursos Estudiantiles IPG">
  {/* CAMBIAMOS <section> por <header> para solucionar el warning semántico */}
  <header class="mt-4 relative z-50">
    <div
      class="relative rounded-3xl p-8 md:p-16 border border-white bg-white/60 backdrop-blur-xl shadow-xl shadow-slate-200/50 flex flex-col items-center text-center group"
    >
      {
        /* --- INICIO EFECTOS DE FONDO ESPECTACULARES (Estilo Bokeh Mágico) --- */
      }
      <div
        class="absolute inset-0 w-full h-full pointer-events-none z-0 overflow-hidden rounded-3xl"
      >
        <div
          class="absolute -top-20 left-1/2 transform -translate-x-1/2 w-[800px] h-[400px] bg-white rounded-full mix-blend-overlay filter blur-[100px] opacity-90 animate-pulse-slow"
        >
        </div>

        <div
          class="absolute -top-32 -right-24 w-[500px] h-[500px] bg-gradient-to-br from-[#00d2ff] to-[#0077ff] rounded-full mix-blend-multiply filter blur-[120px] opacity-40 animate-blob"
        >
        </div>
        <div
          class="absolute -bottom-40 -left-32 w-[600px] h-[600px] bg-gradient-to-tr from-[#003399] to-[#0077ff] rounded-full mix-blend-multiply filter blur-[130px] opacity-40 animate-blob animation-delay-2000"
        >
        </div>
        <div
          class="absolute top-1/2 left-1/4 w-[400px] h-[400px] bg-[#00aaff] rounded-full mix-blend-overlay filter blur-[100px] opacity-30 animate-blob animation-delay-4000"
        >
        </div>

        <div
          class="absolute top-1/4 left-[20%] w-2 h-2 bg-white rounded-full shadow-[0_0_15px_4px_#ffffff,0_0_30px_10px_#0077ff] animate-sparkle"
        >
        </div>
        <div
          class="absolute top-1/3 right-[25%] w-3 h-3 bg-white rounded-full shadow-[0_0_20px_5px_#ffffff,0_0_40px_12px_#00d2ff] animate-sparkle animation-delay-2000"
        >
        </div>
        <div
          class="absolute bottom-1/3 left-[30%] w-1.5 h-1.5 bg-white rounded-full shadow-[0_0_10px_3px_#ffffff,0_0_20px_8px_#003399] animate-sparkle animation-delay-4000"
        >
        </div>
        <div
          class="absolute top-[60%] right-[30%] w-2.5 h-2.5 bg-white rounded-full shadow-[0_0_15px_4px_#ffffff,0_0_35px_10px_#00aaff] animate-sparkle animation-delay-1000"
        >
        </div>
        <div
          class="absolute top-1/5 left-1/2 w-1.5 h-1.5 bg-white rounded-full shadow-[0_0_15px_4px_#ffffff,0_0_30px_10px_#0077ff] animate-sparkle animation-delay-3000"
        >
        </div>
      </div>
      {/* --- FIN EFECTOS DE FONDO --- */}

      {/* CONTENIDO PRINCIPAL */}
      <div class="relative z-10 max-w-3xl flex flex-col items-center">
        <span
          class="inline-block py-1.5 px-4 rounded-full bg-white/80 backdrop-blur-md border border-blue-100 text-[#0077ff] text-xs md:text-sm font-bold mb-6 tracking-wider uppercase shadow-sm"
        >
          Plataforma de Recursos Estudiantiles
        </span>

        <h1
          class="text-4xl md:text-6xl lg:text-7xl font-black text-slate-900 mb-6 tracking-tight leading-[1.1]"
        >
          Bienvenido a <br class="hidden md:block" />
          <span
            class="text-transparent bg-clip-text bg-gradient-to-r from-[#003399] via-[#0077ff] to-[#00d2ff]"
          >
            CRAE IPG
          </span>
        </h1>

        <p
          class="text-lg md:text-xl text-slate-600 max-w-2xl leading-relaxed mb-10 font-medium"
        >
          Encuentra guías, normativas, formatos institucionales y herramientas
          digitales diseñadas para impulsar tu éxito académico en IPG.
        </p>

        <HeroSearch client:load />
      </div>
    </div>
  </header>
  {/* <-- Cerramos con <header> */}

  <WelcomeSection client:load />

  <ResourceGrid client:load />
</Layout>

<style is:global>
  @keyframes blob {
    0% {
      transform: translate(0px, 0px) scale(1);
    }
    33% {
      transform: translate(40px, -60px) scale(1.1);
    }
    66% {
      transform: translate(-30px, 40px) scale(0.9);
    }
    100% {
      transform: translate(0px, 0px) scale(1);
    }
  }
  @keyframes sparkle {
    0%,
    100% {
      opacity: 0;
      transform: scale(0.5);
    }
    50% {
      opacity: 1;
      transform: scale(1.3);
    }
  }
  @keyframes pulse-slow {
    0%,
    100% {
      opacity: 0.7;
    }
    50% {
      opacity: 1;
    }
  }
  .animate-blob {
    animation: blob 8s infinite ease-in-out;
  }
  .animate-sparkle {
    animation: sparkle 4s infinite ease-in-out;
  }
  .animate-pulse-slow {
    animation: pulse-slow 6s infinite ease-in-out;
  }
  .animation-delay-1000 {
    animation-delay: 1s;
  }
  .animation-delay-2000 {
    animation-delay: 2s;
  }
  .animation-delay-3000 {
    animation-delay: 3s;
  }
  .animation-delay-4000 {
    animation-delay: 4s;
  }
</style>
