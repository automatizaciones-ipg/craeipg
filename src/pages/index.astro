--- import Layout from "../layouts/Layout.astro"; import ResourceGrid from
"../components/ResourceGrid.tsx"; import WelcomeSection from
"../components/WelcomeSection.tsx"; import HeroSearch from
"../components/HeroSearch.tsx"; ---

<Layout title="CRAE - Centro de Recursos Estudiantiles IPG">
  <header class="mt-4 relative z-50">
    <div
      class="relative rounded-3xl p-8 md:p-16 border border-white bg-white/60 backdrop-blur-xl shadow-xl shadow-slate-200/50 flex flex-col items-center text-center group"
    >
      {
        /* ... (TODO TU CÓDIGO DE DESTELLOS MAGÍCOS SE MANTIENE EXACTAMENTE IGUAL AQUÍ) ... */
      }

      <div class="relative z-10 max-w-3xl flex flex-col items-center">
        {/* ... (TUS TEXTOS SE MANTIENEN IGUAL) ... */}

        {/* Buscador: client:load porque está arriba y es crítico */}
        <HeroSearch client:load />
      </div>
    </div>
  </header>

  {
    /* OPTIMIZACIÓN ARQUITECTÓNICA: Solo cargan su JS si el usuario hace scroll hacia ellos */
  }
  <WelcomeSection client:visible />
  <ResourceGrid client:visible />
</Layout>

<style is:global>
  @keyframes blob {
    0% {
      transform: translate(0px, 0px) scale(1);
    }
    33% {
      transform: translate(40px, -60px) scale(1.1);
    }
    66% {
      transform: translate(-30px, 40px) scale(0.9);
    }
    100% {
      transform: translate(0px, 0px) scale(1);
    }
  }
  @keyframes sparkle {
    0%,
    100% {
      opacity: 0;
      transform: scale(0.5);
    }
    50% {
      opacity: 1;
      transform: scale(1.3);
    }
  }
  @keyframes pulse-slow {
    0%,
    100% {
      opacity: 0.7;
    }
    50% {
      opacity: 1;
    }
  }
  .animate-blob {
    animation: blob 8s infinite ease-in-out;
  }
  .animate-sparkle {
    animation: sparkle 4s infinite ease-in-out;
  }
  .animate-pulse-slow {
    animation: pulse-slow 6s infinite ease-in-out;
  }
  .animation-delay-1000 {
    animation-delay: 1s;
  }
  .animation-delay-2000 {
    animation-delay: 2s;
  }
  .animation-delay-3000 {
    animation-delay: 3s;
  }
  .animation-delay-4000 {
    animation-delay: 4s;
  }
</style>
